# Production — copy to .env.production.local before `npm run build:prod`
# Vercel: set these in Project → Settings → Environment Variables (Production).

# Backend API origin (no trailing slash, no /api).
# Split deploy: https://your-api.vercel.app
# Same-host Docker: http://api:4000 (internal) or your public API URL
NEXT_PUBLIC_API_URL=https://your-backend.vercel.app

# Optional realtime (Pusher)
NEXT_PUBLIC_REALTIME_KEY=
NEXT_PUBLIC_REALTIME_CLUSTER=

# Local production test only — Next rewrites when NEXT_PUBLIC_API_URL is empty
# API_PROXY_TARGET=http://localhost:4000
