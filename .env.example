# Copy to .env.local for local overrides.

# API origin WITHOUT a trailing slash and WITHOUT /api.
# Leave empty for local dev (Next.js rewrites /api to localhost:4000).
NEXT_PUBLIC_API_URL=

# Optional: managed realtime (Pusher-compatible). Leave empty to disable.
NEXT_PUBLIC_REALTIME_KEY=
NEXT_PUBLIC_REALTIME_CLUSTER=

# Used by next.config.ts rewrites in local dev only (not exposed to browser).
API_PROXY_TARGET=http://localhost:4000
